# API Configuration
DERIBIT_API_KEY=your_deribit_api_key_here
DERIBIT_SECRET_KEY=your_deribit_secret_key_here
DERIBIT_TESTNET=true

# Data Configuration
DATA_CACHE_ENABLED=true
DATA_CACHE_TTL=300
UPDATE_FREQUENCY=30

# Dashboard Configuration
STREAMLIT_PORT=8501
DEBUG_MODE=true
LOG_LEVEL=INFO

# Risk Management
MAX_POSITION_SIZE=1000000
DEFAULT_RISK_LEVEL=0.05
STRESS_TEST_ENABLED=true

# Feature Flags
ENABLE_VOLATILITY_SURFACES=true
ENABLE_GAMMA_EXPOSURE=true
ENABLE_IV_RV_ANALYSIS=true
ENABLE_STATISTICAL_ANALYSIS=true